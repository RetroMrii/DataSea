@baseUrl = http://localhost:5000/api
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiI2YTJmZGY1OTVmZjM2ZWE2NmY2OWY1NWYiLCJyb2xlIjoidXNlciIsImlhdCI6MTc4MTUyMjI3MSwiZXhwIjoxNzgyMTI3MDcxfQ.0j8XRybHUMF3jHLJHfARBT_COcbL73frD8xwmtEDyQ8
@reportId = paste_report_id_here

### Upload without token should fail
POST {{baseUrl}}/reports/upload
Content-Type: multipart/form-data; boundary=DataSeaBoundary

--DataSeaBoundary
Content-Disposition: form-data; name="dataset"; filename="sales-sample.csv"
Content-Type: text/csv

< ./sample-files/sales-sample.csv
--DataSeaBoundary--

### Upload with wrong field name should fail
POST {{baseUrl}}/reports/upload
Authorization: Bearer {{token}}
Content-Type: multipart/form-data; boundary=DataSeaBoundary

--DataSeaBoundary
Content-Disposition: form-data; name="file"; filename="sales-sample.csv"
Content-Type: text/csv

< ./sample-files/sales-sample.csv
--DataSeaBoundary--

### Upload unsupported TXT file should fail
POST {{baseUrl}}/reports/upload
Authorization: Bearer {{token}}
Content-Type: multipart/form-data; boundary=DataSeaBoundary

--DataSeaBoundary
Content-Disposition: form-data; name="dataset"; filename="bad.txt"
Content-Type: text/plain

< ./sample-files/bad.txt
--DataSeaBoundary--

### Save report without token should fail
POST {{baseUrl}}/reports
Content-Type: application/json

{
  "title": "Unauthorized save attempt"
}

### Save report validation error should fail
POST {{baseUrl}}/reports
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "A"
}

### Get report with invalid ObjectId should fail cleanly
GET {{baseUrl}}/reports/not-a-valid-id
Authorization: Bearer {{token}}

### Update report validation error should fail
PUT {{baseUrl}}/reports/{{reportId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "A"
}

### Delete report with invalid ObjectId should fail cleanly
DELETE {{baseUrl}}/reports/not-a-valid-id
Authorization: Bearer {{token}}